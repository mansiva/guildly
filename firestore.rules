rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isMember(groupId) {
      return exists(/databases/$(database)/documents/groupMembers/$(groupId + '_' + request.auth.uid));
    }

    function isAdmin(groupId) {
      return get(/databases/$(database)/documents/groupMembers/$(groupId + '_' + request.auth.uid)).data.role in ['admin', 'owner'];
    }

    function isOwner(groupId) {
      return get(/databases/$(database)/documents/groupMembers/$(groupId + '_' + request.auth.uid)).data.role == 'owner';
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /groups/{groupId} {
      allow read: if request.auth != null && isMember(groupId);
      allow create: if request.auth != null;
      allow update: if request.auth != null && isMember(groupId);
      allow delete: if request.auth != null && isOwner(groupId);

      match /quests/{questId} {
        allow read: if request.auth != null && isMember(groupId);
        allow create, update, delete: if request.auth != null && isAdmin(groupId);
      }

      match /feed/{entryId} {
        allow read: if request.auth != null && isMember(groupId);
        allow create: if request.auth != null && isMember(groupId);
      }
    }

    match /groupMembers/{memberDoc} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /invites/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
  }
}
