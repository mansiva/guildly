rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isMember(groupId) {
      return exists(/databases/$(database)/documents/groupMembers/$(groupId + '_' + request.auth.uid));
    }

    function isAdmin(groupId) {
      return get(/databases/$(database)/documents/groupMembers/$(groupId + '_' + request.auth.uid)).data.role in ['admin', 'owner'];
    }

    function isOwner(groupId) {
      return get(/databases/$(database)/documents/groupMembers/$(groupId + '_' + request.auth.uid)).data.role == 'owner';
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /groups/{groupId} {
      allow read: if request.auth != null && isMember(groupId);
      allow create: if request.auth != null;
      allow update: if request.auth != null && isMember(groupId);
      allow delete: if request.auth != null && isOwner(groupId);

      match /quests/{questId} {
        allow read: if request.auth != null && isMember(groupId);
        allow create, update, delete: if request.auth != null && isAdmin(groupId);
      }

      match /feed/{entryId} {
        allow read: if request.auth != null && isMember(groupId);
        allow create: if request.auth != null && isMember(groupId);
      }
    }

    match /groupMembers/{memberDoc} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /invites/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /friendships/{docId} {
      // Only the two users in the friendship can read/write it
      allow read: if request.auth != null &&
        (resource.data.userA == request.auth.uid || resource.data.userB == request.auth.uid);
      allow create: if request.auth != null &&
        (request.resource.data.userA == request.auth.uid || request.resource.data.userB == request.auth.uid);
      allow update: if request.auth != null &&
        (resource.data.userA == request.auth.uid || resource.data.userB == request.auth.uid);
    }

    match /friendInvites/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    match /nudges/{nudgeDoc} {
      // Authenticated users can read nudge docs where they are sender or recipient.
      // Doc ID format: {senderId}_{recipientId}
      // Use request.auth.uid in the doc ID check to handle non-existent docs safely.
      allow read: if request.auth != null &&
        (nudgeDoc.matches(request.auth.uid + '_.*') || nudgeDoc.matches('.*_' + request.auth.uid));
      // Only the sender can create/update (server-side API handles the actual write via Admin SDK)
      // Client-side reads are the main use case; writes go through /api/nudge
      allow write: if request.auth != null &&
        nudgeDoc.matches(request.auth.uid + '_.*');
    }
  }
}
